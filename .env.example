# Paystack Configuration (Required for dynamic electricity provider fetching)
# Get your API key from https://dashboard.paystack.com/settings/developers
VITE_PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Monnify Configuration (Optional - for bank transfer payments)
VITE_MONNIFY_PUBLIC_KEY=your_monnify_public_key_here
VITE_MONNIFY_CONTRACT_CODE=your_monnify_contract_code_here
